<!-- HTML içindeki metinleri bu şekilde işaretle -->
<h1 data-key="welcome">Hello Debian World!</h1>
<p data-key="desc">Started from scratch and coding.</p>

<!-- Dil Seçici (Dropdown) Menüsü -->
